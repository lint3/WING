    {
      "id": "smt_top_01",
      "template": "step_page",
      "slots": {
        "step_number": "SMT-01",
        "step_title": "Top-Side Component Placement",
        "instructions": "1. Verify CCA top side is clean and free of contamination.\n2. Load program P-7800-TOP into pick-and-place machine.\n3. Place all components per BOM reference designators.\n4. Verify polarity on U1, U3, U5, D1–D4.\n5. Run AOI inspection; record results on traveler.",
        "image": "assets/images/smt_top_ref.jpg",
        "callouts": [],
        "warnings": [
          {
            "type": "warning",
            "text": "ESD-sensitive assembly — wear wrist strap at all times."
          }
        ],
        "extra_elements": []
      }
    },
    {
      "id": "reflow_01",
      "template": "step_page",
      "slots": {
        "step_number": "SMT-02",
        "step_title": "Reflow Solder — Top Side",
        "instructions": "1. Load profile 7800-TOP-LF into reflow oven.\n2. Verify profile matches lead-free solder paste specification.\n3. Run first article; record thermal profile results.\n4. Process remaining boards.\n5. Perform visual inspection per IPC-A-610 Class 3.",
        "image": "assets/images/reflow_profile_7800.png",
        "callouts": [],
        "warnings": [
          {
            "type": "caution",
            "text": "Verify lead-free profile is loaded. Leaded profile will cause cold joints."
          }
        ],
        "extra_elements": []
      }
    },
    {
      "id": "xray_01",
      "template": "xray_page",
      "slots": {
        "xray_image": "assets/images/xray_u3.jpg",
        "components": "U3 (QFN-48), U5 (QFN-32)",
        "criteria": "Inspect for voiding < 25% of solder joint area. No bridging between adjacent pads. All perimeter pads must show wetting.",
        "extra_elements": []
      }
    },
    {
      "id": "tha_01",
      "template": "step_page",
      "slots": {
        "step_number": "THA-01",
        "step_title": "Through-Hole Assembly — Connectors",
        "instructions": "1. Insert J1, J2, J3 per assembly drawing.\n2. Verify connector orientation — pin 1 marked on silkscreen.\n3. Wave solder or hand solder per process specification.\n4. Trim leads flush to 0.020\" ± 0.010\".\n5. Clean flux residue with approved solvent.",
        "image": "assets/images/tha_connectors.jpg",
        "callouts": [
          { "text": "Pin 1", "position": { "x": 1.2, "y": 1.8 } }
        ],
        "warnings": [
          {
            "type": "note",
            "text": "J2 is keyed — do not force. If pins do not align, verify orientation."
          }
        ],
        "extra_elements": []
      }
    },
    {
      "id": "dni_01",
      "template": "dni_page",
      "slots": {
        "assembly_view_id": "assets/cca/board_top.svg",
        "view": "top",
        "dni_components": ["R47", "R48", "C22", "C23", "Q3"],
        "notes": "These positions are populated only on Rev D and later. Do not install on Rev C assemblies.",
        "extra_elements": []
      }
    },
    {
      "id": "conformal_coat_01",
      "template": "step_page",
      "slots": {
        "step_number": "CC-01",
        "step_title": "Conformal Coat Application",
        "instructions": "1. Mask connectors J1, J2, J3 and test points TP1–TP4 with masking tape.\n2. Apply HumiSeal 1B31 per spray specification SP-0042.\n3. Coat thickness: 0.001\"–0.003\". Verify with wet film gauge.\n4. Cure per manufacturer instructions (24 hrs ambient or 1 hr at 60 °C).\n5. Remove masking and inspect coverage.",
        "image": "assets/images/coat_coverage.jpg",
        "callouts": [],
        "warnings": [
          {
            "type": "warning",
            "text": "Use approved respirator when spraying. Refer to SDS for HumiSeal 1B31."
          }
        ],
        "extra_elements": []
      }
    },
    {
      "id": "label_01",
      "template": "step_page",
      "slots": {
        "step_number": "LBL-01",
        "step_title": "Serial Number Label Application",
        "instructions": "1. Print label using label program LP-7800-SN from network share.\n2. Verify serial number format: 7800A-24-XXXX.\n3. Apply label to location indicated in reference photo.\n4. Scan QR code to verify it links to the correct traveler record.",
