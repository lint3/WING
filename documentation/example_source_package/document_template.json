{
  "schema_version": 1,
  "name": "Standard Work Instructions Template",
  "description": "Company-wide base template for assembly work instructions",
  "page_units": "inch",

  "element_templates": {
    "red_warning_box": {
      "description": "Prominent Warning",
      "slots": {
        "warning_text": {
          "type": "text",
          "description": "Warning Message Text"
        }
      },
      "elements": [
        {
          "type": "rectangle",
          "dims": [5, 3],
          "loc": [0, 0],
          "line_thickness_pt": 10,
          "line_color:": "#ff0000ff"
        },
        {
          "type": "text",
          "dims": [4.5, 2.5],
          "loc": [0.25, 0.25],
          "font_color": "#ff0000ff",
          "content": "{{warning_text}}"
        }
      ]
    },
    "basic_circle": {
      "description": "Dummy circle element template",
      "elements": [
        {
          "type": "circle",
          "dims": [3, 3],
          "line_thickness_pt": 3
        }
      ]
    }
  },

  "page_templates": {
    "empty_base": {
      "description": "Empty base landscape letter page",
      "page_width": 11,
      "page_height": 8.5,
      "page_margin": 0.125,
      "page_background": "#ffffffff",
      "font_size_pt": 10,
      "font": "Arial",
      "font_color": "#000000ff",
      "line_thickness_pt": "hairline",
      "line_color": "#000000ff",
      "fill_color": "#00000000",
      "extra_vars": {
        "dni_color": {
          "type": "color",
          "description": "DNI Component Highlight",
          "value": "#ff0000a0"
        },
        "polarity_color": {
          "type": "color",
          "description": "Polarized Component Highlight",
          "value": "#f080d0a0"
        },
        "line_color": {
          "type": "color",
          "description": "Line Color",
          "value": "#000000ff"
        }
      }
    },

    "header_footer": {
      "description": "Basic page with only header and footer",
      "parent": "empty_base",
      "slots": {
        "page_title": { "type": "text", "description": "Page title" },
        "assembly_number": { "type": "text", "description": "Assembly Number" },
        "assembly_rev": { "type": "text", "description": "Assembly Rev" }
      },
      "elements": {
        "assembly_title": {
          "type": "text",
          "loc": [0.5, 0.5],
          "dims": [2, 0.25],
          "content": "{{assembly_number}} Rev {{assembly_rev}}"
        },
        "page_title": {
          "type": "text",
          "loc": [2.5, 0.5],
          "dims": [2, 0.25],
          "content": "{{page_title}}"
        },
        "center_content_box": {
          "type": "rectangle",
          "loc": [0, 0],
          "dims": [10.5, 8]
        }
      }
    },

    "large_center_image": {
      "description": "Large image, and text box on right side",
      "parent": "header_footer",
      "slots": {
        "center_image": {
          "type": "image",
          "description": "Primary image on center of page"
        },
        "instruction_text": {
          "type": "rich_text",
          "description": "Instruction text on right hand side"
        }
      },
      "elements": {
        "center_image": {
          "loc": [0.5, 0, 5],
          "dims": [8, 7]
        },
        "instruction_text": {
          "loc": [9, 0.5],
          "dims": [1.5, 7]
        }
      }
    }
  }
}
